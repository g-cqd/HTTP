# Load-test artifacts and reference-server build output — regenerated by run.sh, never committed.
# (Patterns only — .gitignore does not support trailing inline comments.)
results/
*.pid
# Self-signed TLS material generated for the HTTP2=1 run — never commit keys/certs.
*.pem
# SwiftPM build output for the nested framework packages.
hummingbird/.build/
vapor/.build/
# Cargo build output (hyper/tokio crates + the rust-bench binary).
rust/target/
# Python virtualenv (django/gunicorn/uvicorn), regenerated by run.sh.
django/.venv/
__pycache__/
*.pyc
