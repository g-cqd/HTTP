# Load-test artifacts and any reference-server build output — regenerated by run.sh, never committed.
results/
*.pid
*.pem        # self-signed TLS material generated for the HTTP2=1 run — never commit keys/certs
hummingbird/.build/
rust/target/         # cargo build output (hyper/tokio crates + the rust-bench binary)
django/.venv/        # Python virtualenv (django/gunicorn/uvicorn), regenerated by run.sh
__pycache__/
*.pyc
