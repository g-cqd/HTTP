# Benchmarking/Bench/servers/Caddyfile — modern Go server (native h1/h2/h3), mirroring httpd-example's routes.
#
# Run via:  caddy run --config <abs path>/Caddyfile --adapter caddyfile
# Listens on 8082 (matches Benchmarking/Bench/run.sh PORT_CADDY). Admin + auto-HTTPS off so the cleartext h1/h2
# throughput is what we measure; for the h3 comparison, front it with TLS and add `protocols h1 h2 h3`.

{
	admin off
	auto_https off
	persist_config off
}

:8082 {
	@root path /
	respond @root "Hello from the Caddy baseline.\n" 200

	@health path /health
	respond @health "OK\n" 200

	# Parity routes (the heavier-workload scenarios). Caddy cannot echo a POST body without a plugin,
	# so it does not implement /echo — the harness marks that cell N/A.
	@json path /json
	handle @json {
		header Content-Type application/json
		respond `{"message":"Hello, World!"}` 200
	}

	@payload path /payload
	respond @payload "__PAYLOAD__" 200

	@hello path_regexp hello ^/hello/(.+)$
	respond @hello "Hello, {re.hello.1}!\n" 200
}
